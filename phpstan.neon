includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:
    level: 5

    paths:
        - app
        - config
        - database
        - routes

    # The codebase is clean at level 5 with no baseline. New code must satisfy
    # level 5; any regression fails the check. If a temporary baseline is ever
    # needed again, regenerate it with:
    #   composer analyse -- --generate-baseline
    # and add it back to the includes above.

    # Eloquent magic columns aren't statically known.
    checkModelProperties: false
